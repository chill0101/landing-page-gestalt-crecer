---
import Layout from '../components/Layout.astro';
---

<Layout>
  <div class="main-content">
    <div class="dashboard-card">
      <h1>Contáctanos</h1>
      <p>No dudes en escribirnos para más información sobre nuestros servicios terapéuticos o para coordinar una cita.</p>
      
      <div class="contact-container">
        <div class="contact-info">
          <h2>Información de Contacto</h2>
          <ul>
            <li><strong>Email:</strong> crecer_jugando@hotmail.com</li>
            <li><strong>WhatsApp:</strong> <a href="https://wa.link/v6x6ct" target="_blank">+54 11 5099-3973</a></li>
            <li><strong>Instagram:</strong> <a href="https://www.instagram.com/crecerjugando.gestalt/" target="_blank">@crecerjugando.gestalt</a></li>
            <li><strong>Facebook:</strong> <a href="https://www.facebook.com/crecerjugando.gestalt/" target="_blank">Taller Crecer Jugando</a></li>
            <li><strong>Horario:</strong> Lun-Vie: 9AM - 19PM | Sáb: 10AM - 14PM</li>
            <li><strong>Ubicación:</strong> Palermo, CABA (Atención Online disponible)</li>
          </ul>
          
          <h2>Envíanos un Mensaje</h2>
          <form 
            class="form-container" 
            id="contact-form"
            autocomplete="off"
            novalidate
          >
            <!-- Honeypot anti-spam (oculto) -->
            <div class="hp-field" aria-hidden="true">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
            </div>
            
            <div class="form-group">
              <label for="name" class="form-label">Nombre</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                class="form-input" 
                placeholder="Tu nombre" 
                maxlength="100"
                autocomplete="off"
              >
            </div>
            
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                class="form-input" 
                placeholder="Tu email" 
                maxlength="254"
                autocomplete="off"
              >
            </div>
            
            <div class="form-group">
              <label for="subject" class="form-label">Asunto</label>
              <input 
                type="text" 
                id="subject" 
                name="subject" 
                class="form-input" 
                placeholder="Motivo de tu consulta"
                maxlength="200"
                autocomplete="off"
              >
            </div>
            
            <div class="form-group">
              <label for="message" class="form-label">Mensaje</label>
              <textarea 
                id="message" 
                name="message" 
                class="form-textarea" 
                placeholder="Tu mensaje..." 
                maxlength="2000"
                autocomplete="off"
              ></textarea>
            </div>
            
            <!-- Cloudflare Turnstile -->
            <div class="cf-turnstile" data-sitekey="0x4AAAAAAADJ_kXqC8LdG8VFl"></div>
            
            <div id="form-message"></div>
            <button type="submit" class="btn btn-block" id="submit-btn">Enviar Mensaje</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" defer></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    const messageDiv = document.getElementById('form-message');
    const submitBtn = document.getElementById('submit-btn');
    const hpField = document.getElementById('website');
    
    // Honeypot check - si se filled, es un bot
    if (hpField.value !== '') {
      console.log('Bot detected via honeypot');
      return;
    }
    
    // Validación JavaScript adicional
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const email = document.getElementById('email').value;
      const name = document.getElementById('name').value;
      const subject = document.getElementById('subject')?.value || '';
      const message = document.getElementById('message').value;
      
      // Sanitización básica
      const sanitizedEmail = email.replace(/[<>]/g, '').trim();
      const sanitizedName = name.replace(/[<>]/g, '').trim();
      const sanitizedSubject = subject.replace(/[<>]/g, '').trim();
      const sanitizedMessage = message.replace(/[<>]/g, '').trim();
      
      // Validación deemail válido
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(sanitizedEmail)) {
        showMessage('Por favor ingresa un email válido', 'error');
        return;
      }
      
      // Validación de longitud mínima
      if (sanitizedMessage.length < 10) {
        showMessage('El mensaje debe tener al menos 10 caracteres', 'error');
        return;
      }
      
      // Check para spam keywords
      const spamKeywords = ['viagra', 'casino', 'lottery', 'winner', 'click here', 'free money', 'nigerian', 'bitcoin', 'crypto'];
      const lowerMessage = sanitizedMessage.toLowerCase();
      for (const keyword of spamKeywords) {
        if (lowerMessage.includes(keyword)) {
          showMessage('Tu mensaje fue marcado como spam. Por favor contactanos directamente.', 'error');
          return;
        }
      }
      
      // Disable button durante envío
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      
      try {
        const response = await fetch('https://formspree.io/f/mwvrvbep', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ 
            name: sanitizedName, 
            email: sanitizedEmail, 
            subject: sanitizedSubject,
            message: sanitizedMessage 
          })
        });
        
        if (response.ok) {
          showMessage('¡Gracias! Tu mensaje ha sido enviado correctamente. Te responderemos a la brevedad.', 'success');
          form.reset();
        } else {
          showMessage('Hubo un error al enviar. Por favor intentá de nuevo.', 'error');
        }
      } catch (error) {
        showMessage('Hubo un error al enviar. Por favor intentá de nuevo.', 'error');
      }
      
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar Mensaje';
    });
    
    function showMessage(msg, type) {
      messageDiv.innerHTML = `<div class="form-${type}">${escapeHtml(msg)}</div>`;
      messageDiv.style.display = 'block';
    }
    
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
    
    // Prevenir XSS en inputs en tiempo real
    const inputs = form.querySelectorAll('input, textarea');
    inputs.forEach(input => {
      input.addEventListener('input', function() {
        // Limitar caracteres especiales peligrosos
        this.value = this.value.replace(/[<>'"]/g, '');
      });
    });
  });
</script>

<style>
  .contact-container {
    max-width: 700px;
    margin-top: 2rem;
  }
  
  .contact-info ul {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
  }
  
  .contact-info li {
    padding: 0.75rem 0;
    border-bottom: 1px solid #eee;
    font-size: 1.1rem;
  }
  
  .contact-info h2 {
    color: var(--primary-color);
    margin-bottom: 1rem;
  }
  
  .contact-info h2:first-of-type {
    margin-top: 0;
  }
  
  /* Honeypot - oculto visualmente */
  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }
  
  .cf-turnstile {
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }
  
  #form-message {
    margin-bottom: 1rem;
  }
  
  .form-error {
    background: var(--light-color);
    color: var(--error-color);
    padding: 0.75rem;
    border-radius: 6px;
    border-left: 4px solid var(--error-color);
  }
  
  .form-success {
    background: var(--light-color);
    color: var(--success-color);
    padding: 0.75rem;
    border-radius: 6px;
    border-left: 4px solid var(--success-color);
  }
  
  #submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
</style>